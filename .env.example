# Django Environment Variables
# Copy this file to .env and fill in your actual values

# SECURITY SETTINGS
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,schoolms,0.0.0.0

# DATABASE SETTINGS
DB_ENGINE=django.db.backends.postgresql
DB_NAME=school_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=db
DB_PORT=5432

# CORS SETTINGS (for django-cors-headers)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOW_CREDENTIALS=True

# OPTIONAL: If you want to use DATABASE_URL instead of individual DB vars
# DATABASE_URL=postgresql://postgres:postgres@db:5432/school_db

# DEVELOPMENT SETTINGS
DJANGO_SETTINGS_MODULE=management.settings